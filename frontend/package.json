    "@xterm/xterm": "^5.5.0",
    "axios": "^1.6.7",
    "echarts": "^5.5.0",
    "element-plus": "^2.5.6",
    "js-yaml": "^4.1.0",
    "monaco-editor": "^0.50.0",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.19",
    "vue-echarts": "^6.6.9",
    "vue-router": "^4.3.0",
    "vue-i18n": "^9.13.0"
