# Kube Admin 部署环境变量示例。
# 复制为 .env 并按需修改：cp .env.example .env

# ===== 服务 =====
PORT=8080
GIN_MODE=release

# KUBECONFIG：集群内部署留空（自动用 ServiceAccount）；
# compose 单机部署若要管宿主机所在集群，需把 kubeconfig 挂载进容器并在此指定路径。
# KUBECONFIG=/app/config/kubeconfig

# ===== 密钥（生产必填！生成：openssl rand -base64 32）=====
# ENCRYPT_KEY 丢失将导致已存的集群凭据无法解密，请妥善备份。
JWT_SECRET=
ENCRYPT_KEY=

# ===== 数据库 =====
# DB_DRIVER: sqlite | mysql | postgres
DB_DRIVER=sqlite
# 仅 DB_DRIVER=sqlite 生效
DB_PATH=/data/kubeadm.db
# mysql/postgres 时填 DSN，示例：
# DB_DSN=root:root@tcp(mysql:3306)/kubeadm?charset=utf8mb4&parseTime=True&loc=Local
# DB_DSN=host=postgres user=kubeadmin password=secret dbname=kubeadm port=5432 sslmode=disable TimeZone=Asia/Shanghai
DB_DSN=

# ===== 其他 =====
TLS_SKIP_VERIFY=false
# k8s API 单次请求超时（秒，默认 10）：集群不可达时快速失败，避免 client-go 默认挂起 30s
# K8S_REQUEST_TIMEOUT=10
